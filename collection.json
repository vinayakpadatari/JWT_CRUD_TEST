{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-4789-a0b1-000000000002",
    "name": "JWT + CRUD Demo",
    "description": "Register, log in, and manage notes against the JWT demo API. Run 'Login' first to auto-save the token for the protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/register",
          "host": ["{{baseUrl}}"],
          "path": ["register"]
        }
      }
    },
    {
      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data.token) {",
              "    pm.environment.set('token', data.token);",
              "    console.log('Token saved to environment');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": ["{{baseUrl}}"],
          "path": ["login"]
        }
      }
    },
    {
      "name": "Get Notes",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/notes",
          "host": ["{{baseUrl}}"],
          "path": ["notes"]
        }
      }
    },
    {
      "name": "Create Note",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const data = pm.response.json();",
              "if (data._id) {",
              "    pm.environment.set('noteId', data._id);",
              "    console.log('noteId saved to environment');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"My first note\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/notes",
          "host": ["{{baseUrl}}"],
          "path": ["notes"]
        }
      }
    },
    {
      "name": "Update Note",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Updated note text\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/notes/{{noteId}}",
          "host": ["{{baseUrl}}"],
          "path": ["notes", "{{noteId}}"]
        }
      }
    },
    {
      "name": "Delete Note",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/notes/{{noteId}}",
          "host": ["{{baseUrl}}"],
          "path": ["notes", "{{noteId}}"]
        }
      }
    }
  ]
}